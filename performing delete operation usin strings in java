import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	   Scanner sc = new Scanner(System.in);
	   String str = sc.next();
	   String email = " ";
	   
	   for(int i = 0; i<str.length(); i++){
	       if(str.charAt(i)== '@'){
	           break;
	       }else{
	           email += str.charAt(i);
	       }
	   }
	   System.out.println(email);
	}
}
