import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	    Scanner sc = new Scanner(System.in);
	    int size = sc.nextInt();
	    sc.nextLine();
	    
	    String arr[] = new String[size];
	    int totalLength = 0;
	    for(int i = 0;i<size;i++){
	        arr[i] = sc.nextLine();
	        totalLength += arr[i].length();
	    }
	    System.out.println("Cummulative Length" + totalLength);
	}
}
